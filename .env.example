# Compose deployment. CONATUS_VERSION must match a published release image tag
# without the leading "v" (for example, GitHub release v0.2.0 -> 0.2.0).
CONATUS_VERSION=latest
# Override these only when deploying images from a fork or another registry.
# CONATUS_IMAGE=ghcr.io/nojusmorkunas/conatus
# CONATUS_MCP_IMAGE=ghcr.io/nojusmorkunas/conatus-mcp
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-with-a-long-url-safe-password
POSTGRES_DB=app

# Used when running the application directly with npm. Compose supplies its own
# internal database URL from the POSTGRES_* values above.
DATABASE_URL=postgres://app:replace-with-a-long-url-safe-password@localhost:5432/app
# Set both to the external HTTPS origin when using a domain/reverse proxy.
# AUTH_URL=https://tasks.example.com
# PUBLIC_BASE_URL=https://tasks.example.com
AUTH_SECRET=generate-with-npx-auth-secret
# Optional one-time bootstrap. Set both before the first `docker compose up`.
# The job creates a verified administrator only when the database is empty.
# Remove both values and the stopped bootstrap container after first login.
# CONATUS_ADMIN_USERNAME=admin
# CONATUS_ADMIN_PASSWORD=replace-with-a-long-random-password
# Registration is invite-only by default. The first account bootstraps the
# server and becomes its administrator.
# REGISTRATION_MODE=invite-only
S3_ENDPOINT=localhost
S3_PORT=9000
S3_ACCESS_KEY=replace-with-a-random-access-key
S3_SECRET_KEY=replace-with-a-long-random-secret-key
S3_BUCKET=attachments
# Email is disabled unless all three values are configured.
# SMTP_HOST=mail.example.com
# SMTP_PORT=587
# SMTP_FROM="Conatus <conatus@example.com>"
# Optional endpoint that receives JSON error reports.
# ERROR_WEBHOOK_URL=

# Optional remote MCP sidecar (docker compose --profile mcp up --build).
# Create TASKS_API_TOKEN in Settings. Prefer OAuth for connect-by-URL clients.
# TASKS_API_TOKEN=tdm_replace_me
# MCP_PUBLIC_URL=https://mcp.example.com/mcp
# MCP_OAUTH_PASSWORD=generate-a-separate-long-random-password
# MCP_ALLOWED_ORIGINS=https://your-ai-host.example
# Static fallback when the client cannot use OAuth:
# MCP_BEARER_TOKEN=generate-a-long-random-token
